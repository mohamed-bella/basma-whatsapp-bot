# ── Bot ────────────────────────────────────────────────────────────────────────
BOT_NAME=Basma Travel Bot

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
API_SECRET=your-strong-secret-key-here

# ── WhatsApp Business Cloud API ────────────────────────────────────────────────
# Get these from: https://developers.facebook.com → Your App → WhatsApp → API Setup

# Your permanent System User token (or temporary test token)
WHATSAPP_TOKEN=your_access_token_here

# The Phone Number ID (NOT the phone number itself — the numeric ID from Meta dashboard)
WHATSAPP_PHONE_ID=your_phone_number_id_here

# API version (check Meta docs for latest)
WHATSAPP_API_VERSION=v22.0

# ── Webhook ────────────────────────────────────────────────────────────────────
# A secret string YOU invent — must match what you set in Meta App → Webhooks config
WEBHOOK_VERIFY_TOKEN=basma_verify_token_2024

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
